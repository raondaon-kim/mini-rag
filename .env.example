# ============================================
# Mini-RAG Configuration
# ============================================

# Claude API (Required)
# Get your key from: https://console.anthropic.com
ANTHROPIC_API_KEY=your-api-key-here

# Server
PORT=4001

# Document paths
DOCS_PATH=./docs      # Auto-indexed on startup
DATA_PATH=./data      # SQLite DB + generated files

# Database
DB_PATH=./data/rag.sqlite

# Note: Vector embedding (all-MiniLM-L6-v2) runs locally.
# No OpenAI key needed.
